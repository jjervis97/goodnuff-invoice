def vin_year_from_char(code: str) -> str:
    code = code.upper()
    year_map = {
        "A": 2010, "B": 2011, "C": 2012, "D": 2013, "E": 2014,
        "F": 2015, "G": 2016, "H": 2017, "J": 2018, "K": 2019,
        "L": 2020, "M": 2021, "N": 2022, "P": 2023, "R": 2024,
        "S": 2025, "T": 2026, "V": 2027, "W": 2028, "X": 2029,
        "Y": 2030,
        "1": 2001, "2": 2002, "3": 2003, "4": 2004, "5": 2005,
        "6": 2006, "7": 2007, "8": 2008, "9": 2009,
    }
    return str(year_map.get(code, "Unknown"))

def vin_decode_local(vin: str) -> dict[str, str]:
    v = vin.strip().upper()

    if len(v) != 17:
        return {"vin": v, "error": f"VIN must be 17 chars (got {len(v)})"}

    country = VIN_COUNTRY.get(v[0], "Unknown / other")
    wmi = v[:3]
    make = VIN_WMI.get(wmi, "Unknown manufacturer")
    year_code = v[9]
    model_year = vin_year_from_char(year_code)
    plant = v[10]
    serial = v[11:]
    check_digit = v[8]

    return {
        "vin": v,
        "country": country,
        "make": make,
        "model_year": model_year,
        "plant": plant,
        "serial": serial,
        "check_digit": check_digit,
    }

def vin_fetch_online(vin: str):
    """
    Call NHTSA VPIC API and return the full JSON response dict,
    or None if something goes wrong.
    """
    url = f"https://vpic.nhtsa.dot.gov/api/vehicles/decodevin/{vin}?format=json"

    try:
        result = subprocess.run(
            ["curl", "-s", url],
            capture_output=True,
            text=True,
            check=False,
            timeout=10,
        )
    except Exception as e:
        print(f"\n[!] Online VIN lookup error: {e}")
        return None

    if result.returncode != 0 or not result.stdout.strip():
        print("\n[!] Online VIN lookup failed (network or curl problem).")
        return None

    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError:
        print("\n[!] Could not parse NHTSA response (invalid JSON).")
        return None

    return data

def vpic_field(results: list, name: str) -> str:
    """Find a VPIC variable by name inside Results list."""
    for row in results:
        if row.get("Variable") == name:
            value = row.get("Value")
            if value not in (None, ""):
                return str(value)
    return ""

def vin_online_full_print(vin: str) -> None:
    """Run NHTSA online decode and print all specs in the terminal."""
    data = vin_fetch_online(vin)
    if not data:
        # vin_fetch_online already printed an error
        return

    results = data.get("Results", [])

    # --- Quick summary first ---
    make = vpic_field(results, "Make")
    model = vpic_field(results, "Model")
    year = vpic_field(results, "Model Year") or vpic_field(results, "ModelYear")
    body = vpic_field(results, "Body Class")
    engine_l = vpic_field(results, "Displacement (L)")
    cyl = vpic_field(results, "Engine Number of Cylinders")
    fuel = vpic_field(results, "Fuel Type - Primary")

    print("\n" + "=" * 60)
    print(" ONLINE VIN DECODE (NHTSA)")
    print("=" * 60)
    print(f"VIN           : {vin}")
    print(f"Year / Make   : {year} {make}".strip())
    print(f"Model         : {model}")
    print(f"Body Class    : {body}")
    if engine_l or cyl:
        print(f"Engine        : {engine_l}L {cyl} cyl".strip())
    if fuel:
        print(f"Fuel          : {fuel}")

    # --- Plant info (if present) ---
    plant_city = vpic_field(results, "Plant City")
    plant_state = vpic_field(results, "Plant State")
    plant_country = vpic_field(results, "Plant Country")
    plant_bits = [plant_city, plant_state, plant_country]
    plant = ", ".join([p for p in plant_bits if p])
    if plant:
        print(f"Plant         : {plant}")

    # --- All non-empty variables ---
    print("\nAll decoded variables:")
    print("-" * 60)
    for row in results:
        var = row.get("Variable")
        val = row.get("Value")
        if var and val not in (None, ""):
            print(f"{var}: {val}")

def vin_open_full_in_browser(vin: str) -> None:
    """Open the human-friendly NHTSA VIN decoder page in Chrome."""
    url = f"https://vpic.nhtsa.dot.gov/decoder/Decoder?VIN={vin}"
    try:
        subprocess.Popen(
            ["xdg-open", url],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,  # quiet Chrome logs in this terminal
        )
    except FileNotFoundError:
        print("\nCould not auto-open browser. You can visit this URL instead:")
        print(url)

def save_vin_history(vin_info: dict, online: dict | None) -> None:
    VIN_HISTORY.parent.mkdir(parents=True, exist_ok=True)
    new_file = not VIN_HISTORY.exists()
    with VIN_HISTORY.open("a", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        if new_file:
            writer.writerow([
                "timestamp", "vin", "country", "manufacturer", "model_year",
                "online_make", "online_model", "online_year"
            ])
        ts = datetime.utcnow().isoformat(timespec="seconds")
        writer.writerow([
            ts,
            vin_info["vin"],
            vin_info["country"],
            vin_info["manufacturer"],
            vin_info["model_year"] or "",
            (online or {}).get("Make", ""),
            (online or {}).get("Model", ""),
            (online or {}).get("ModelYear", ""),
        ])

def run_vin_quick_decode() -> None:
    os.system("clear")
    gn_header("VIN QUICK DECODE")

    vin = input("\nEnter VIN (blank to cancel): ").strip()
    if not vin:
        return

    v = vin_clean(vin)

    if len(v) != 17 or any(c in VIN_FORBIDDEN for c in v):
        print("\n!! VIN looks invalid (length or forbidden characters: I, O, Q).")
        print(f"You entered: {v}")
        pause()
        return

    info = vin_decode_local(v)

    info.setdefault("manufacturer", info.get("make", "Unknown"))
    info.setdefault("make", info.get("manufacturer", "Unknown"))

    print("\nLocal decode:")
    print("-" * 60)
    print(f"VIN         : {info['vin']}")
    print(f"Country     : {info['country']}")
    print(f"Manufacturer: {info['manufacturer']}")
    print(f"Model year  : {info['model_year'] or 'Unknown'}")
    print(f"Plant code  : {info.get('plant', info.get('plant_code', '?'))}")
    print(f"Serial      : {info['serial']}")
    
    check = info.get("check_digit")
    if check:
        print(f"Check digit : {check}")

    print()
    use_online = input("\nRun online NHTSA decode as well? [Y/n]: ").strip().lower()
    if use_online in ("", "y", "yes"):
        vin_online_full_print(vin)
        pause()  # if you have a pause() helper so you can read it
