def gn_header(title: str) -> None:
    os.system("clear")

    # Try to generate the figlet banner; fall back to plain text if figlet is missing
    try:
        banner = subprocess.check_output(
            ["figlet", "-f", "small", "GOOD 'NUFF GARAGE"],
            text=True
        )
    except Exception:
        banner = "GOOD 'NUFF GARAGE"

    lines = banner.splitlines()

    # Animated print of the figlet banner (cyan + bold)
    for line in lines:
        colored = f"{CYAN}{BOLD}{line}{RESET}"
        print(colored.center(80))
        time.sleep(0.04)  # tweak speed if you want faster/slower

    # Title bar under the banner
    bar = "-" * 50
    print()
    print(f"{YELLOW}{bar.center(80)}{RESET}")
    print(f"{CYAN}{title.center(80)}{RESET}")
    print(f"{YELLOW}{bar.center(80)}{RESET}")
    print()

