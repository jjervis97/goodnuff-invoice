        print("\nNo invoices have been recorded yet.")
        pause()
        return

    rows: list[list[str]] = []
    with INVOICES_CSV.open("r", encoding="utf-8", newline="") as f:
        reader = csv.reader(f)
        for row in reader:
            rows.append(row)

